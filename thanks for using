-- make reopen button draggable separately
do
	local draggingReopen = false
	local dragStartReopen
	local startPosReopen

	registerConnection(ReopenButton.InputBegan:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
			draggingReopen = true
			dragStartReopen = Vector2.new(input.Position.X, input.Position.Y)
			startPosReopen = ReopenButton.Position
			input.Changed:Connect(function()
				if input.UserInputState == Enum.UserInputState.End then
					draggingReopen = false
				end
			end)
		end
	end))

	registerConnection(ReopenButton.InputChanged:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then
			dragInput = input
		end
	end))

	registerConnection(UserInputService.InputChanged:Connect(function(input)
		if draggingReopen and input == dragInput then
			local inputPos = Vector2.new(input.Position.X, input.Position.Y)
			local delta = inputPos - dragStartReopen
			ReopenButton.Position = UDim2.new(
				startPosReopen.X.Scale,
				startPosReopen.X.Offset + delta.X,
				startPosReopen.Y.Scale,
				startPosReopen.Y.Offset + delta.Y
			)
		end
	end))

	registerConnection(UserInputService.InputEnded:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
			draggingReopen = false
		end
	end))
end

