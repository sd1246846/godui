function Tab:AddColorPicker(opts)
    opts = opts or {}
    local cb      = opts.callback or function() end
    local current = opts.default or Color3.fromRGB(255,255,255)
    local ch      = {r=math.round(current.R*255),g=math.round(current.G*255),b=math.round(current.B*255)}

    local row=Instance.new("Frame")
    row.BackgroundColor3=T.s2 row.BorderSizePixel=0
    row.Size=UDim2.new(1,0,0,26)
    crn(row,4) pad(row,0,0,8,8)
    row.Parent=self._cf

    lbl(row,{text=opts.text or "Color",size=12,color=T.textPri,sz=UDim2.new(0.7,0,1,0)})

    local swatch=Instance.new("Frame")
    swatch.AnchorPoint=Vector2.new(1,0.5) swatch.Position=UDim2.new(1,0,0.5,0)
    swatch.Size=UDim2.new(0,16,0,16) swatch.BackgroundColor3=current swatch.BorderSizePixel=0
    crn(swatch,3) stroke(swatch,T.border,1)
    swatch.Parent=row

    -- Expanded panel
    local panel=Instance.new("Frame")
    panel.BackgroundColor3=T.s1 panel.BorderSizePixel=0
    panel.Size=UDim2.new(1,0,0,102) panel.Position=UDim2.new(0,0,1,2)
    panel.Visible=false panel.ZIndex=20
    crn(panel,4) pad(panel,6,6,6,6)
    stroke(panel,T.border,1)
    list(panel,4)
    panel.Parent=row

    local function refresh()
        current=Color3.fromRGB(ch.r,ch.g,ch.b)
        swatch.BackgroundColor3=current cb(current)
    end

    local colNames = {"R","G","B"}
    local colKeys  = {"r","g","b"}
    for i=1,3 do
        local key=colKeys[i]
        local slRow=Instance.new("Frame")
        slRow.BackgroundTransparency=1 slRow.Size=UDim2.new(1,0,0,24) slRow.LayoutOrder=i slRow.ZIndex=21
        slRow.Parent=panel

        lbl(slRow,{text=colNames[i],size=10,color=T.textMut,sz=UDim2.new(0,12,1,0),z=21})

        local tr=Instance.new("Frame")
        tr.BackgroundColor3=T.s0 tr.BorderSizePixel=0
        tr.Position=UDim2.new(0,16,0.5,-3) tr.Size=UDim2.new(1,-38,0,6) tr.ZIndex=21
        crn(tr,3) tr.Parent=slRow

        local fi=Instance.new("Frame")
        fi.BackgroundColor3=T.accent fi.BorderSizePixel=0
        fi.Size=UDim2.new(ch[key]/255,0,1,0) fi.ZIndex=22 crn(fi,3) fi.Parent=tr

        local kn=Instance.new("Frame")
        kn.AnchorPoint=Vector2.new(0.5,0.5) kn.Position=UDim2.new(ch[key]/255,0,0.5,0)
        kn.Size=UDim2.new(0,8,0,8) kn.BackgroundColor3=Color3.fromRGB(255,255,255)
        kn.BorderSizePixel=0 kn.ZIndex=23 crn(kn,4) kn.Parent=tr

        local vl=lbl(slRow,{size=10,color=T.accent,align=Enum.TextXAlignment.Right,
            sz=UDim2.new(0,22,1,0),pos=UDim2.new(1,-22,0,0),z=21})
        vl.Text=tostring(ch[key])

        local dc=false
        tr.InputBegan:Connect(function(inp)
            if inp.UserInputType==Enum.UserInputType.MouseButton1 then
                dc=true
                local p=math.clamp((inp.Position.X-tr.AbsolutePosition.X)/tr.AbsoluteSize.X,0,1)
                ch[key]=math.round(p*255) fi.Size=UDim2.new(p,0,1,0) kn.Position=UDim2.new(p,0,0.5,0) vl.Text=tostring(ch[key]) refresh()
            end
        end)
        UserInputService.InputChanged:Connect(function(inp)
            if dc and inp.UserInputType==Enum.UserInputType.MouseMovement then
                local p=math.clamp((inp.Position.X-tr.AbsolutePosition.X)/tr.AbsoluteSize.X,0,1)
                ch[key]=math.round(p*255) fi.Size=UDim2.new(p,0,1,0) kn.Position=UDim2.new(p,0,0.5,0) vl.Text=tostring(ch[key]) refresh()
            end
        end)
        UserInputService.InputEnded:Connect(function(inp)
            if inp.UserInputType==Enum.UserInputType.MouseButton1 then dc=false end
        end)
    end

    local open=false
    local sc=Instance.new("TextButton")
    sc.BackgroundTransparency=1 sc.Size=UDim2.new(1,0,1,0) sc.Text="" sc.ZIndex=25 sc.Parent=swatch
    sc.MouseButton1Click:Connect(function()
        open=not open
        panel.Visible=open
        row.Size=open and UDim2.new(1,0,0,130) or UDim2.new(1,0,0,26)
    end)
    row.MouseEnter:Connect(function() if not open then tw(row,0.1,{BackgroundColor3=T.s3}) end end)
    row.MouseLeave:Connect(function() if not open then tw(row,0.1,{BackgroundColor3=T.s2}) end end)

    return {
        GetColor=function(_) return current end,
        SetColor=function(_,c)
            current=c swatch.BackgroundColor3=c
            ch.r=math.round(c.R*255) ch.g=math.round(c.G*255) ch.b=math.round(c.B*255)
        end,
    }
end

-- ── AddKeybind ──────────────────────────────────────────────
--  opts: text, key (Enum.KeyCode|nil), callback
--  Click the badge to rebind. Press key to set, ESC to clear.
-- ─────────────────────────────────────────────────────────────
function Tab:AddKeybind(opts)
    opts = opts or {}
    local cb         = opts.callback or function() end
    local currentKey = opts.key
    local id         = tostring(math.random(1e9))

    local row=Instance.new("Frame")
    row.BackgroundColor3=T.s2 row.BorderSizePixel=0
    row.Size=UDim2.new(1,0,0,26)
    crn(row,4) pad(row,0,0,8,8)
    row.Parent=self._cf

    lbl(row,{text=opts.text or "Keybind",size=12,color=T.textPri,sz=UDim2.new(0.55,0,1,0)})

    -- Badge
    local badge=Instance.new("TextButton")
    badge.Font=Enum.Font.GothamSemibold
    badge.Text=keyName(currentKey)
    badge.TextSize=10
    badge.TextColor3=T.accent
    badge.BackgroundColor3=T.s0
    badge.BorderSizePixel=0
    badge.AnchorPoint=Vector2.new(1,0.5)
    badge.Position=UDim2.new(1,0,0.5,0)
    badge.Size=UDim2.new(0,54,0,16)
    badge.AutoButtonColor=false
    crn(badge,3)
    stroke(badge,T.border,1)
    badge.Parent=row

    local listening=false

    local function setL(v)
        listening=v
        if v then
            badge.Text="…"
            badge.TextColor3=T.danger
            tw(badge,0.1,{BackgroundColor3=Color3.fromRGB(50,28,28)})
        else
            badge.Text=keyName(currentKey)
            badge.TextColor3=T.accent
            tw(badge,0.1,{BackgroundColor3=T.s0})
        end
    end

    badge.MouseButton1Click:Connect(function() setL(not listening) end)
    badge.MouseEnter:Connect(function() if not listening then tw(badge,0.08,{BackgroundColor3=T.s2}) end end)
    badge.MouseLeave:Connect(function() if not listening then tw(badge,0.08,{BackgroundColor3=T.s0}) end end)

    UserInputService.InputBegan:Connect(function(inp, gp)
        if listening then
            if inp.UserInputType==Enum.UserInputType.Keyboard then
                currentKey=(inp.KeyCode==Enum.KeyCode.Escape) and nil or inp.KeyCode
                for _,b in ipairs(_binds) do if b.id==id then b.key=currentKey break end end
                setL(false)
            end
            return
        end
        if gp then return end
        if inp.UserInputType==Enum.UserInputType.Keyboard and currentKey and inp.KeyCode==currentKey then
            pcall(cb, currentKey)
        end
    end)

    table.insert(_binds, {id=id, key=currentKey, fn=function() end})

    row.MouseEnter:Connect(function() tw(row,0.1,{BackgroundColor3=T.s3}) end)
    row.MouseLeave:Connect(function() tw(row,0.1,{BackgroundColor3=T.s2}) end)

    return {
        GetKey=function(_) return currentKey end,
        SetKey=function(_,k)
            currentKey=k badge.Text=keyName(k)
            for _,b in ipairs(_binds) do if b.id==id then b.key=k break end end
        end,
        Unbind=function(_)
            currentKey=nil badge.Text="—"
            for _,b in ipairs(_binds) do if b.id==id then b.key=nil break end end
        end,
    }
end

