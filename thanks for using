-- Shared UIS reference used by all drag logic
local _UIS = game:GetService("UserInputService")
local _TS  = game:GetService("TweenService")

-- bringToFront: elevate a GuiObject above all siblings
local function bringToFront(gui)
    local mx = 0
    for _, v in ipairs(gui.Parent:GetChildren()) do
        if v:IsA("GuiObject") and v.ZIndex > mx then mx = v.ZIndex end
    end
    if gui.ZIndex <= mx then
        local diff = (mx + 1) - gui.ZIndex
        gui.ZIndex = mx + 1
        for _, c in ipairs(gui:GetDescendants()) do
            if c:IsA("GuiObject") then c.ZIndex = c.ZIndex + diff end
        end
    end
end

-- makeDraggable: attach drag behaviour to a GuiObject.
--   handle    = the element the user grabs (defaults to target itself)
--   onlyOnce  = if true, only wire up once even if called again
--
-- Returns a disconnect function so you can stop dragging if needed.
local function makeDraggable(target, handle)
    handle = handle or target

    local dragging  = false
    local dragInput = nil
    local dragStart = nil
    local startPos  = nil

    -- Safely read screen size — fallback to workspace camera viewport
    local function screenSize()
        local sg = target.Parent
        if sg and sg:IsA("ScreenGui") then
            return sg.AbsoluteSize
        end
        return game:GetService("Workspace").CurrentCamera.ViewportSize
    end

    local function update(inp)
        if not dragging then return end
        local delta = Vector2.new(inp.Position.X, inp.Position.Y) - dragStart
        local sc    = screenSize()
        local sz    = target.AbsoluteSize
        local newX  = math.clamp(startPos.X.Offset + delta.X, 0, sc.X - sz.X)
        local newY  = math.clamp(startPos.Y.Offset + delta.Y, 0, sc.Y - sz.Y)
        target.Position = UDim2.new(0, newX, 0, newY)
    end

    handle.InputBegan:Connect(function(inp)
        if inp.UserInputType == Enum.UserInputType.MouseButton1
        or inp.UserInputType == Enum.UserInputType.Touch then
            dragging  = true
            dragStart = Vector2.new(inp.Position.X, inp.Position.Y)
            startPos  = target.Position
            -- Make sure position uses only offset (no scale) from here
            target.Position = UDim2.new(0, target.AbsolutePosition.X, 0, target.AbsolutePosition.Y)
            startPos  = target.Position
        end
    end)

    handle.InputChanged:Connect(function(inp)
        if inp.UserInputType == Enum.UserInputType.MouseMovement
        or inp.UserInputType == Enum.UserInputType.Touch then
            dragInput = inp
        end
    end)

    _UIS.InputChanged:Connect(function(inp)
        if inp == dragInput and dragging then update(inp) end
    end)

    _UIS.InputEnded:Connect(function(inp)
        if inp.UserInputType == Enum.UserInputType.MouseButton1
        or inp.UserInputType == Enum.UserInputType.Touch then
            dragging  = false
            dragInput = nil
        end
    end)
end

