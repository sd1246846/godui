    local isOpen   = false
    local CH, OH   = 26, 22

    -- wrapper so the dropdown can grow downward
    local wrap = Instance.new("Frame")
    wrap.BackgroundTransparency = 1
    wrap.Size           = UDim2.new(1, -8, 0, CH)
    wrap.ClipsDescendants = false
    wrap.LayoutOrder    = nextOrder(self)
    wrap.ZIndex         = 5
    wrap.Parent         = self._cf

    local header = Instance.new("Frame")
    header.BackgroundColor3 = T.s2
    header.BorderSizePixel  = 0
    header.Size             = UDim2.new(1, 0, 0, CH)
    header.ZIndex           = 6
    crn(header, 4)
    pad(header, 0, 0, 8, 6)
    header.Parent = wrap

    local nameLbl = mkLabel(header, opts.text or "Dropdown", 12, T.textPri)
    nameLbl.Size  = UDim2.new(0.55, 0, 1, 0)
    nameLbl.ZIndex = 6

    local selLbl  = mkLabel(header, tostring(selected) .. " ▾", 11, T.accent, Enum.TextXAlignment.Right)
    selLbl.Size     = UDim2.new(0.45, 0, 1, 0)
    selLbl.Position = UDim2.new(0.55, 0, 0, 0)
    selLbl.ZIndex   = 6

    local drop = Instance.new("Frame")
    drop.BackgroundColor3 = T.s0
    drop.BorderSizePixel  = 0
    drop.Position         = UDim2.new(0, 0, 0, CH + 1)
    drop.Size             = UDim2.new(1, 0, 0, 0)
    drop.ClipsDescendants = true
    drop.ZIndex           = 10
    crn(drop, 4)
    drop.Parent = wrap
    makeListLayout(drop, 0)

    local function addOpt(optText)
        local ob = Instance.new("TextButton")
        ob.Font             = Enum.Font.Gotham
        ob.Text             = "  " .. tostring(optText)
        ob.TextSize         = 11
        ob.TextColor3       = T.textSec
        ob.TextXAlignment   = Enum.TextXAlignment.Left
        ob.BackgroundColor3 = T.s0
        ob.BorderSizePixel  = 0
        ob.Size             = UDim2.new(1, 0, 0, OH)
        ob.ZIndex           = 11
        ob.AutoButtonColor  = false
        ob.Parent           = drop

        ob.MouseButton1Click:Connect(function()
            selected      = optText
            selLbl.Text   = tostring(selected) .. " ▾"
            cb(selected)
            isOpen = false
            tw(drop, 0.12, {Size = UDim2.new(1, 0, 0, 0)})
            task.delay(0.12, function()
                if not isOpen then wrap.Size = UDim2.new(1, -8, 0, CH) end
            end)
        end)
        ob.MouseEnter:Connect(function() tw(ob, 0.08, {BackgroundColor3 = T.s2, TextColor3 = T.textPri}) end)
        ob.MouseLeave:Connect(function() tw(ob, 0.08, {BackgroundColor3 = T.s0, TextColor3 = T.textSec}) end)
    end

    for _, o in ipairs(options) do addOpt(o) end

    local click = Instance.new("TextButton")
    click.BackgroundTransparency = 1
    click.Size   = UDim2.new(1, 0, 1, 0)
    click.Text   = ""
    click.ZIndex = 12
    click.Parent = header

    click.MouseButton1Click:Connect(function()
        isOpen = not isOpen
        local h = isOpen and (#options * OH) or 0
        tw(drop, 0.14, {Size = UDim2.new(1, 0, 0, h)})
        if isOpen then
            wrap.Size = UDim2.new(1, -8, 0, CH + h + 1)
        else
            task.delay(0.14, function()
                if not isOpen then wrap.Size = UDim2.new(1, -8, 0, CH) end
            end)
        end
        selLbl.Text = tostring(selected) .. (isOpen and " ▴" or " ▾")
    end)
    header.MouseEnter:Connect(function() tw(header, 0.1, {BackgroundColor3 = T.s3}) end)
    header.MouseLeave:Connect(function() tw(header, 0.1, {BackgroundColor3 = T.s2}) end)

    return {
        SetValue   = function(_, v) selected = v selLbl.Text = tostring(v) .. " ▾" end,
        GetValue   = function(_) return selected end,
        SetOptions = function(_, newOpts)
            options = newOpts
            for _, c in ipairs(drop:GetChildren()) do
                if c:IsA("TextButton") then c:Destroy() end
            end
            for _, o in ipairs(newOpts) do addOpt(o) end
        end,
    }
end

