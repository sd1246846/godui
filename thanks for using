local _binds = {}

UserInputService.InputBegan:Connect(function(inp, gp)
    if gp or inp.UserInputType ~= Enum.UserInputType.Keyboard then return end
    for _, b in ipairs(_binds) do
        if b.key and inp.KeyCode == b.key then pcall(b.fn) end
    end
end)

