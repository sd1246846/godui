-- ── 3. Minimize (−) ↔ Reopen pill ──────────────────────────
-- When minimised:
--   • pill appears at the window's current screen position
--   • pill is fully draggable and screen-clamped
-- When reopened:
--   • window appears at wherever the pill was dragged to
local function IKUPSQ_fake_script()
    local s         = Instance.new("LocalScript"); s.Parent = Converted["_-"]
    local mainFrame = s.Parent.Parent               -- "god lib"  Frame
    local screenGui = mainFrame.Parent              -- "godlib"   ScreenGui
    local reopen    = screenGui:WaitForChild("reopen")

    reopen.Visible = false

    local pillDraggable = false

    s.Parent.MouseButton1Click:Connect(function()
        -- Convert window's current absolute position into a 0-scale UDim2
        -- so the pill starts right where the window was
        local ap = mainFrame.AbsolutePosition
        reopen.Position = UDim2.new(0, ap.X, 0, ap.Y)
        mainFrame.Visible = false
        reopen.Visible    = true

        -- Wire drag exactly once
        if not pillDraggable then
            pillDraggable = true
            makeDraggable(reopen, reopen)
        end
    end)

    reopen.MouseButton1Click:Connect(function()
        -- Only reopen, don't also trigger drag-start on this click
        local ap = reopen.AbsolutePosition
        mainFrame.Position = UDim2.new(0, ap.X, 0, ap.Y)
        mainFrame.Visible  = true
        reopen.Visible     = false
        bringToFront(mainFrame)
    end)
end

