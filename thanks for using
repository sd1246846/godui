    do local ss=Instance.new("UIStroke"); ss.Color=T.border; ss.Thickness=1; ss.Parent=drop end
    newListLayout(drop, 0)

    local function addOpt(optText)
        local ob=Instance.new("TextButton")
        ob.Font=Enum.Font.Gotham; ob.Text="  "..tostring(optText)
        ob.TextSize=11; ob.TextColor3=T.sub; ob.TextXAlignment=Enum.TextXAlignment.Left
        ob.BackgroundColor3=T.bg; ob.BorderSizePixel=0
        ob.Size=UDim2.new(1,0,0,OH); ob.ZIndex=11; ob.AutoButtonColor=false
        ob.Parent=drop
        ob.MouseButton1Click:Connect(function()
            selected=optText; selLbl.Text=tostring(selected).." ▾"; cb(selected)
            isOpen=false; tw(drop,0.12,{Size=UDim2.new(1,0,0,0)})
            task.delay(0.12,function() if not isOpen then wrap.Size=UDim2.new(1,-8,0,CH) end end)
        end)
        ob.MouseEnter:Connect(function() tw(ob,0.08,{BackgroundColor3=T.card,TextColor3=T.text}) end)
        ob.MouseLeave:Connect(function() tw(ob,0.08,{BackgroundColor3=T.bg,TextColor3=T.sub}) end)
    end
    for _,o in ipairs(options) do addOpt(o) end

    header.MouseButton1Click:Connect(function()
        isOpen=not isOpen
        local h=isOpen and (#options*OH) or 0
        tw(drop,0.14,{Size=UDim2.new(1,0,0,h)})
        if isOpen then wrap.Size=UDim2.new(1,-8,0,CH+h+1)
