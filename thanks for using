-- CreateTab(name, icon?, iconSource?)
--   icon       = Lucide name e.g. "zap"
--   iconSource = "Lucide" (default) | "Custom" (rbxassetid)
function Window:CreateTab(name, icon, iconSource)
    local tab = setmetatable({}, Tab)
    tab._win  = self

    -- ── Tab button (44px wide sidebar) ──
    local btn=Instance.new("TextButton")
    btn.BackgroundColor3=T.s0
    btn.BorderSizePixel=0
    btn.Size=UDim2.new(1,-4,0,40)
    btn.Text="" btn.AutoButtonColor=false
    crn(btn,4)
    btn.Parent=Converted["_tabsframe"]
    tab._btn=btn

    -- Accent indicator bar (left edge, hidden when inactive)
    local bar=Instance.new("Frame")
    bar.BackgroundColor3=T.accent
    bar.BorderSizePixel=0
    bar.AnchorPoint=Vector2.new(0,0.5)
    bar.Position=UDim2.new(0,0,0.5,0)
    bar.Size=UDim2.new(0,2,0.5,0)
    bar.Visible=false
    crn(bar,1) bar.Parent=btn
    tab._bar=bar

    if icon then
        local img=Instance.new("ImageLabel")
        img.BackgroundTransparency=1
        img.AnchorPoint=Vector2.new(0.5,0.5)
        img.Position=UDim2.new(0.5,0,0.38,0)
        img.Size=UDim2.new(0,16,0,16)
        img.ImageColor3=T.textMut
        img.ScaleType=Enum.ScaleType.Fit
        img.Parent=btn
        tab._img=img

        task.spawn(function()
            local asset=GetIcon(icon, iconSource or "Lucide")
            if asset then ApplyIcon(img, asset)
            else
                img:Destroy() tab._img=nil
                local fb=lbl(btn,{text=string.sub(name,1,3),size=9,color=T.textMut,
                    sz=UDim2.new(1,-2,0,14),pos=UDim2.new(0,1,0,5)})
                fb.TextXAlignment=Enum.TextXAlignment.Center
                tab._fallback=fb
            end
        end)

        local nl=lbl(btn,{text=string.sub(name,1,5),size=8,color=T.textMut,
            sz=UDim2.new(1,-2,0,10),pos=UDim2.new(0,1,1,-12)})
        nl.TextXAlignment=Enum.TextXAlignment.Center
        tab._nl=nl
    else
        local tl=lbl(btn,{text=string.sub(name,1,4),size=10,color=T.textMut,
            sz=UDim2.new(1,-4,1,-4),pos=UDim2.new(0,2,0,2)})
        tl.TextXAlignment=Enum.TextXAlignment.Center
        tab._tl=tl
    end

    -- ── Content frame ──
    local cf=Instance.new("ScrollingFrame")
    cf.BackgroundTransparency=1 cf.BorderSizePixel=0
    cf.ScrollBarThickness=2
    cf.ScrollBarImageColor3=T.accent
    cf.ScrollBarImageTransparency=0.5
    cf.Size=UDim2.new(1,0,1,0)
    cf.Visible=#self._tabs==0
    cf.Parent=Converted["_frame"]

    local lay=list(cf, ROW_GAP)
    pad(cf,2,4,0,0)
    lay:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function()
        cf.CanvasSize=UDim2.new(0,0,0,lay.AbsoluteContentSize.Y+6)
    end)
    tab._cf=cf

    -- ── Activate helpers ──
    local function deactivateAll()
        for _,t in ipairs(self._tabs) do
            t._cf.Visible=false
            tw(t._btn,0.14,{BackgroundColor3=T.s0})
            t._bar.Visible=false
            if t._img      then tw(t._img,     0.14,{ImageColor3=T.textMut}) end
            if t._nl       then tw(t._nl,      0.14,{TextColor3=T.textMut}) end
            if t._tl       then tw(t._tl,      0.14,{TextColor3=T.textMut}) end
            if t._fallback then tw(t._fallback,0.14,{TextColor3=T.textMut}) end
        end
    end
    local function activateThis()
        deactivateAll()
        cf.Visible=true
        tw(btn,0.14,{BackgroundColor3=T.s2})
        bar.Visible=true
        if tab._img      then tw(tab._img,     0.14,{ImageColor3=T.textPri}) end
        if tab._nl       then tw(tab._nl,      0.14,{TextColor3=T.textPri}) end
        if tab._tl       then tw(tab._tl,      0.14,{TextColor3=T.textPri}) end
        if tab._fallback then tw(tab._fallback,0.14,{TextColor3=T.textPri}) end
        self._active=tab
    end

    btn.MouseButton1Click:Connect(activateThis)
    btn.MouseEnter:Connect(function()
        if self._active~=tab then tw(btn,0.1,{BackgroundColor3=T.s1}) end
    end)
    btn.MouseLeave:Connect(function()
        if self._active~=tab then tw(btn,0.1,{BackgroundColor3=T.s0}) end
    end)

    if #self._tabs==0 then
        btn.BackgroundColor3=T.s2 bar.Visible=true
        if tab._img      then tab._img.ImageColor3=T.textPri end
        if tab._nl       then tab._nl.TextColor3=T.textPri end
        if tab._tl       then tab._tl.TextColor3=T.textPri end
        self._active=tab
    end

    table.insert(self._tabs, tab)
    task.defer(function()
        local l=Converted["_tabsframe"]:FindFirstChildOfClass("UIListLayout")
        if l then Converted["_tabsframe"].CanvasSize=UDim2.new(0,0,0,l.AbsoluteContentSize.Y+4) end
    end)

    return tab
end

function Window:_def()
    if not self._defaultTab then self._defaultTab=self:CreateTab("Main") end
    return self._defaultTab
end
function Window:AddSection(o)      return self:_def():AddSection(o) end
function Window:AddLabel(o)        return self:_def():AddLabel(o) end
function Window:AddButton(o)       return self:_def():AddButton(o) end
function Window:AddToggle(o)       return self:_def():AddToggle(o) end
function Window:AddSlider(o)       return self:_def():AddSlider(o) end
function Window:AddDropdown(o)     return self:_def():AddDropdown(o) end
function Window:AddTextbox(o)      return self:_def():AddTextbox(o) end
function Window:AddColorPicker(o)  return self:_def():AddColorPicker(o) end
function Window:AddKeybind(o)      return self:_def():AddKeybind(o) end

-- ============================================================
-- LIBRARY ENTRY
-- ============================================================
function Library:CreateWindow(title)
    Converted["_title"].Text = title or "god lib"
    local win=setmetatable({},Window)
    win._tabs={}
    win._defaultTab=nil
    win._active=nil
    return win
end

return Library
