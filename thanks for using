    inputBg.BackgroundColor3 = T.s0
    inputBg.BorderSizePixel  = 0
    inputBg.Size             = UDim2.new(1, 0, 0, 18)
    inputBg.Position         = UDim2.new(0, 0, 0, 16)
    crn(inputBg, 3)
    pad(inputBg, 0, 0, 5, 5)
    inputBg.Parent = row

    local box = Instance.new("TextBox")
    box.Font              = Enum.Font.Gotham
    box.Text              = opts.default or ""
    box.PlaceholderText   = opts.placeholder or "…"
    box.PlaceholderColor3 = T.textMut
    box.TextColor3        = T.textPri
    box.TextSize          = 11
    box.TextXAlignment    = Enum.TextXAlignment.Left
    box.BackgroundTransparency = 1
    box.Size              = UDim2.new(1, 0, 1, 0)
    box.ClearTextOnFocus  = false
    box.Parent            = inputBg

    box.Focused:Connect(function()
        tw(inputBg, 0.1, {BackgroundColor3 = T.s1})
    end)
    box.FocusLost:Connect(function(enter)
        tw(inputBg, 0.1, {BackgroundColor3 = T.s0})
        local v = box.Text
        if opts.numeric then v = tonumber(v) or 0 box.Text = tostring(v) end
        cb(v, enter)
    end)

    return {
        SetText = function(_, t) box.Text = tostring(t) end,
        GetText = function(_) return box.Text end,
    }
end

-- ── AddColorPicker ──────────────────────────────────────────
function Tab:AddColorPicker(opts)
    opts = opts or {}
    local cb      = opts.callback or function() end
    local current = opts.default or Color3.fromRGB(255, 255, 255)
    local ch      = {
        r = math.round(current.R * 255),
        g = math.round(current.G * 255),
        b = math.round(current.B * 255),
    }

    local row = makeRow(self._cf, 26)
    row.LayoutOrder = nextOrder(self)
    pad(row, 0, 0, 8, 8)
    crn(row, 4)
    row.Parent = self._cf

    mkLabel(row, opts.text or "Color", 12, T.textPri).Size = UDim2.new(0.7, 0, 1, 0)

    local swatch = Instance.new("Frame")
    swatch.AnchorPoint    = Vector2.new(1, 0.5)
    swatch.Position       = UDim2.new(1, 0, 0.5, 0)
    swatch.Size           = UDim2.new(0, 16, 0, 16)
    swatch.BackgroundColor3 = current
    swatch.BorderSizePixel = 0
    crn(swatch, 3)
    swatch.Parent = row

    local panel = Instance.new("Frame")
    panel.BackgroundColor3 = T.s1
    panel.BorderSizePixel  = 0
    panel.Size             = UDim2.new(1, 0, 0, 102)
    panel.Position         = UDim2.new(0, 0, 1, 2)
    panel.Visible          = false
    panel.ZIndex           = 20
    crn(panel, 4)
    pad(panel, 6, 6, 6, 6)
    makeListLayout(panel, 4)
    panel.Parent = row

    local function refresh()
        current = Color3.fromRGB(ch.r, ch.g, ch.b)
        swatch.BackgroundColor3 = current
        cb(current)
    end

    for i, sd in ipairs({{l="R",k="r"},{l="G",k="g"},{l="B",k="b"}}) do
        local slRow = Instance.new("Frame")
        slRow.BackgroundTransparency = 1
        slRow.Size        = UDim2.new(1, 0, 0, 24)
        slRow.LayoutOrder = i
        slRow.ZIndex      = 21
        slRow.Parent      = panel

        mkLabel(slRow, sd.l, 10, T.textMut).Size = UDim2.new(0, 12, 1, 0)

        local tr = Instance.new("Frame")
        tr.BackgroundColor3 = T.s0
        tr.BorderSizePixel  = 0
        tr.Position         = UDim2.new(0, 16, 0.5, -3)
        tr.Size             = UDim2.new(1, -38, 0, 6)
        tr.ZIndex           = 21
        crn(tr, 3)
        tr.Parent = slRow

        local fi = Instance.new("Frame")
        fi.BackgroundColor3 = T.accent
        fi.BorderSizePixel  = 0
        fi.Size             = UDim2.new(ch[sd.k] / 255, 0, 1, 0)
        fi.ZIndex           = 22
        crn(fi, 3)
        fi.Parent = tr

        local kn = Instance.new("Frame")
        kn.AnchorPoint      = Vector2.new(0.5, 0.5)
        kn.Position         = UDim2.new(ch[sd.k] / 255, 0, 0.5, 0)
        kn.Size             = UDim2.new(0, 8, 0, 8)
        kn.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
        kn.BorderSizePixel  = 0
        kn.ZIndex           = 23
        crn(kn, 4)
        kn.Parent = tr

        local vl = mkLabel(slRow, tostring(ch[sd.k]), 10, T.accent, Enum.TextXAlignment.Right)
        vl.Size     = UDim2.new(0, 22, 1, 0)
        vl.Position = UDim2.new(1, -22, 0, 0)
        vl.ZIndex   = 21

        local dc = false
        tr.InputBegan:Connect(function(inp)
            if inp.UserInputType == Enum.UserInputType.MouseButton1 then
                dc = true
                local p = math.clamp((inp.Position.X - tr.AbsolutePosition.X) / tr.AbsoluteSize.X, 0, 1)
                ch[sd.k] = math.round(p * 255)
                fi.Size  = UDim2.new(p, 0, 1, 0)
                kn.Position = UDim2.new(p, 0, 0.5, 0)
                vl.Text  = tostring(ch[sd.k])
                refresh()
            end
        end)
        UserInputService.InputChanged:Connect(function(inp)
            if dc and inp.UserInputType == Enum.UserInputType.MouseMovement then
                local p = math.clamp((inp.Position.X - tr.AbsolutePosition.X) / tr.AbsoluteSize.X, 0, 1)
                ch[sd.k] = math.round(p * 255)
                fi.Size  = UDim2.new(p, 0, 1, 0)
                kn.Position = UDim2.new(p, 0, 0.5, 0)
                vl.Text  = tostring(ch[sd.k])
                refresh()
            end
        end)
        UserInputService.InputEnded:Connect(function(inp)
            if inp.UserInputType == Enum.UserInputType.MouseButton1 then dc = false end
        end)
    end

    local panelOpen = false
    local sc = Instance.new("TextButton")
    sc.BackgroundTransparency = 1
    sc.Size   = UDim2.new(1, 0, 1, 0)
    sc.Text   = ""
    sc.ZIndex = 25
    sc.Parent = swatch
    sc.MouseButton1Click:Connect(function()
        panelOpen     = not panelOpen
        panel.Visible = panelOpen
        row.Size      = panelOpen and UDim2.new(1, -8, 0, 130) or UDim2.new(1, -8, 0, 26)
    end)

    return {
        GetColor = function(_) return current end,
        SetColor = function(_, c)
            current = c
            swatch.BackgroundColor3 = c
            ch.r = math.round(c.R * 255)
            ch.g = math.round(c.G * 255)
            ch.b = math.round(c.B * 255)
        end,
    }
end

-- ── AddKeybind ──────────────────────────────────────────────
function Tab:AddKeybind(opts)
    opts = opts or {}
    local cb         = opts.callback or function() end
    local currentKey = opts.key
    local id         = tostring(math.random(1e9))

    local row = makeRow(self._cf, 26)
    row.LayoutOrder = nextOrder(self)
    pad(row, 0, 0, 8, 8)
    crn(row, 4)
    row.Parent = self._cf

    local lbl = mkLabel(row, opts.text or "Keybind", 12, T.textPri)
    lbl.Size  = UDim2.new(0.55, 0, 1, 0)

    local badge = Instance.new("TextButton")
    badge.Font             = Enum.Font.GothamSemibold
    badge.Text             = keyName(currentKey)
    badge.TextSize         = 10
    badge.TextColor3       = T.accent
    badge.BackgroundColor3 = T.s0
    badge.BorderSizePixel  = 0
    badge.AnchorPoint      = Vector2.new(1, 0.5)
    badge.Position         = UDim2.new(1, 0, 0.5, 0)
    badge.Size             = UDim2.new(0, 54, 0, 16)
    badge.AutoButtonColor  = false
    crn(badge, 3)
    badge.Parent = row

    local listening = false

    local function setL(v)
        listening = v
        if v then
            badge.Text      = "…"
            badge.TextColor3 = T.danger
            tw(badge, 0.1, {BackgroundColor3 = Color3.fromRGB(50, 28, 28)})
        else
            badge.Text      = keyName(currentKey)
            badge.TextColor3 = T.accent
            tw(badge, 0.1, {BackgroundColor3 = T.s0})
        end
    end

    badge.MouseButton1Click:Connect(function() setL(not listening) end)

    UserInputService.InputBegan:Connect(function(inp, gp)
        if listening then
            if inp.UserInputType == Enum.UserInputType.Keyboard then
                currentKey = (inp.KeyCode == Enum.KeyCode.Escape) and nil or inp.KeyCode
                for _, b in ipairs(_binds) do
                    if b.id == id then b.key = currentKey break end
                end
                setL(false)
            end
            return
        end
        if gp then return end
        if inp.UserInputType == Enum.UserInputType.Keyboard and currentKey and inp.KeyCode == currentKey then
            pcall(cb, currentKey)
        end
    end)

    table.insert(_binds, {id = id, key = currentKey, fn = function() end})

    row.MouseEnter:Connect(function() tw(row, 0.1, {BackgroundColor3 = T.s3}) end)
    row.MouseLeave:Connect(function() tw(row, 0.1, {BackgroundColor3 = T.s2}) end)

    return {
        GetKey = function(_) return currentKey end,
        SetKey = function(_, k)
            currentKey = k
            badge.Text = keyName(k)
            for _, b in ipairs(_binds) do if b.id == id then b.key = k break end end
        end,
        Unbind = function(_)
            currentKey = nil
            badge.Text = "—"
            for _, b in ipairs(_binds) do if b.id == id then b.key = nil break end end
        end,
    }
end

-- ============================================================
-- WINDOW OBJECT
-- ============================================================
local Window = {}
Window.__index = Window

function Window:CreateTab(name, icon, iconSource)
    local tab     = setmetatable({}, Tab)
    tab._win      = self
    tab._order    = 0   -- component insertion counter

    -- ── Sidebar tab button (44px wide) ──
    local btn = Instance.new("TextButton")
    btn.BackgroundColor3 = T.s0
    btn.BorderSizePixel  = 0
    btn.Size             = UDim2.new(1, -4, 0, 40)
    btn.Text             = ""
    btn.AutoButtonColor  = false
    crn(btn, 4)
    btn.Parent = Converted["_tabsframe"]
    tab._btn   = btn

    -- Active indicator bar
    local bar = Instance.new("Frame")
    bar.BackgroundColor3 = T.accent
    bar.BorderSizePixel  = 0
    bar.AnchorPoint      = Vector2.new(0, 0.5)
    bar.Position         = UDim2.new(0, 0, 0.5, 0)
    bar.Size             = UDim2.new(0, 2, 0.5, 0)
    bar.Visible          = false
    crn(bar, 1)
    bar.Parent = btn
    tab._bar   = bar

    if icon then
        local img = Instance.new("ImageLabel")
        img.BackgroundTransparency = 1
        img.AnchorPoint            = Vector2.new(0.5, 0.5)
        img.Position               = UDim2.new(0.5, 0, 0.38, 0)
        img.Size                   = UDim2.new(0, 16, 0, 16)
        img.ImageColor3            = T.textMut
        img.ScaleType              = Enum.ScaleType.Fit
        img.Parent                 = btn
        tab._img                   = img

        task.spawn(function()
            local asset = GetIcon(icon, iconSource or "Lucide")
            if asset then
                ApplyIcon(img, asset)
            else
                img:Destroy()
                tab._img = nil
                local fb = Instance.new("TextLabel")
                fb.BackgroundTransparency = 1
                fb.Font      = Enum.Font.GothamSemibold
                fb.Text      = string.sub(name, 1, 3)
                fb.TextSize  = 9
                fb.TextColor3 = T.textMut
                fb.TextXAlignment = Enum.TextXAlignment.Center
                fb.AnchorPoint = Vector2.new(0.5, 0.5)
                fb.Position    = UDim2.new(0.5, 0, 0.38, 0)
                fb.Size        = UDim2.new(1, -2, 0, 14)
                fb.Parent      = btn
                tab._fallback  = fb
            end
        end)

        local nl = Instance.new("TextLabel")
        nl.BackgroundTransparency = 1
        nl.Font      = Enum.Font.Gotham
        nl.Text      = string.sub(name, 1, 5)
        nl.TextSize  = 8
        nl.TextColor3 = T.textMut
        nl.TextXAlignment = Enum.TextXAlignment.Center
        nl.AnchorPoint    = Vector2.new(0.5, 1)
        nl.Position       = UDim2.new(0.5, 0, 1, -4)
        nl.Size           = UDim2.new(1, -2, 0, 11)
        nl.Parent         = btn
        tab._nl           = nl
    else
        local tl = Instance.new("TextLabel")
        tl.BackgroundTransparency = 1
        tl.Font      = Enum.Font.GothamSemibold
        tl.Text      = string.sub(name, 1, 4)
        tl.TextSize  = 10
        tl.TextColor3 = T.textMut
        tl.TextXAlignment = Enum.TextXAlignment.Center
        tl.AnchorPoint    = Vector2.new(0.5, 0.5)
        tl.Position       = UDim2.new(0.5, 0, 0.5, 0)
        tl.Size           = UDim2.new(1, -4, 1, -4)
        tl.TextWrapped    = true
        tl.Parent         = btn
        tab._tl           = tl
    end

    -- ── Content ScrollingFrame inside _frame ──
    -- Size = fill _frame fully. Position always (0,0).
    local cf = Instance.new("ScrollingFrame")
    cf.BackgroundTransparency    = 1
    cf.BorderSizePixel           = 0
    cf.ScrollBarThickness        = 2
    cf.ScrollBarImageColor3      = T.accent
    cf.ScrollBarImageTransparency = 0.5
    cf.Position                  = UDim2.new(0, 0, 0, 0)
    cf.Size                      = UDim2.new(1, 0, 1, 0)
    cf.Visible                   = #self._tabs == 0
    cf.Parent                    = Converted["_frame"]
    tab._cf                      = cf

    -- Inner layout with padding
    local lay = makeListLayout(cf, 3)
    pad(cf, 4, 4, 4, 4)

    lay:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function()
        cf.CanvasSize = UDim2.new(0, 0, 0, lay.AbsoluteContentSize.Y + 8)
    end)

    -- ── Activate / deactivate ──
    local function deactivateAll()
        for _, t in ipairs(self._tabs) do
            t._cf.Visible = false
            tw(t._btn, 0.14, {BackgroundColor3 = T.s0})
            t._bar.Visible = false
            if t._img      then tw(t._img,      0.14, {ImageColor3 = T.textMut}) end
            if t._nl       then tw(t._nl,       0.14, {TextColor3  = T.textMut}) end
            if t._tl       then tw(t._tl,       0.14, {TextColor3  = T.textMut}) end
            if t._fallback then tw(t._fallback, 0.14, {TextColor3  = T.textMut}) end
        end
    end

    local function activateThis()
        deactivateAll()
        cf.Visible     = true
        bar.Visible    = true
        tw(btn, 0.14, {BackgroundColor3 = T.s2})
        if tab._img      then tw(tab._img,      0.14, {ImageColor3 = T.textPri}) end
        if tab._nl       then tw(tab._nl,       0.14, {TextColor3  = T.textPri}) end
        if tab._tl       then tw(tab._tl,       0.14, {TextColor3  = T.textPri}) end
        if tab._fallback then tw(tab._fallback, 0.14, {TextColor3  = T.textPri}) end
        self._active = tab
    end

    btn.MouseButton1Click:Connect(activateThis)
    btn.MouseEnter:Connect(function()
        if self._active ~= tab then tw(btn, 0.1, {BackgroundColor3 = T.s1}) end
    end)
    btn.MouseLeave:Connect(function()
        if self._active ~= tab then tw(btn, 0.1, {BackgroundColor3 = T.s0}) end
    end)

    -- First tab is active by default
    if #self._tabs == 0 then
        btn.BackgroundColor3 = T.s2
        bar.Visible          = true
        if tab._img then tab._img.ImageColor3 = T.textPri end
        if tab._nl  then tab._nl.TextColor3   = T.textPri end
        if tab._tl  then tab._tl.TextColor3   = T.textPri end
        self._active = tab
    end

    table.insert(self._tabs, tab)

    -- Refresh tabsframe canvas height
    task.defer(function()
        local l = Converted["_tabsframe"]:FindFirstChildOfClass("UIListLayout")
        if l then
            Converted["_tabsframe"].CanvasSize = UDim2.new(0, 0, 0, l.AbsoluteContentSize.Y + 4)
        end
    end)

    return tab
end

-- Shorthand: auto-create a "Main" tab
function Window:_def()
    if not self._defaultTab then
        self._defaultTab = self:CreateTab("Main")
    end
    return self._defaultTab
end

function Window:AddSection(o)      return self:_def():AddSection(o) end
function Window:AddLabel(o)        return self:_def():AddLabel(o) end
function Window:AddButton(o)       return self:_def():AddButton(o) end
function Window:AddToggle(o)       return self:_def():AddToggle(o) end
function Window:AddSlider(o)       return self:_def():AddSlider(o) end
function Window:AddDropdown(o)     return self:_def():AddDropdown(o) end
function Window:AddTextbox(o)      return self:_def():AddTextbox(o) end
function Window:AddColorPicker(o)  return self:_def():AddColorPicker(o) end
function Window:AddKeybind(o)      return self:_def():AddKeybind(o) end

