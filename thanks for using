		local listening = false

		local holder = styleSectionContainer(self.Page)
		holder.Size = UDim2.new(1, 0, 0, 34)

		local btn = create("TextButton", {
			Font = Enum.Font.FredokaOne,
			Text = tostring(opts.text or "Keybind") .. " : " .. tostring(bindKey.Name),
			TextColor3 = Colors.Text,
			TextSize = 13,
			TextXAlignment = Enum.TextXAlignment.Left,
			BackgroundColor3 = Colors.Main,
			BorderSizePixel = 0,
			Size = UDim2.new(1, 0, 0, 30),
			Parent = holder,
		})
		corner(btn)

		local function refresh()
			btn.Text = tostring(opts.text or "Keybind") .. " : " .. tostring(bindKey.Name)
			if listening then
				btn.Text = tostring(opts.text or "Keybind") .. " : ..."
			end
		end

		registerConnection(btn.MouseButton1Click:Connect(function()
			listening = true
			refresh()
		end))

		registerConnection(UserInputService.InputBegan:Connect(function(input, gpe)
			if gpe then
				return
			end
			if listening then
				if input.UserInputType == Enum.UserInputType.Keyboard then
					bindKey = input.KeyCode
					listening = false
					refresh()
					safeCall(opts.callback, bindKey)
				end
				return
			end
			if input.KeyCode == bindKey then
				safeCall(opts.callback, bindKey)
			end
		end))

		refresh()

		return {
			SetKey = function(_, key)
				if typeof(key) == "EnumItem" then
					bindKey = key
					refresh()
				end
			end,
			GetKey = function()
				return bindKey
			end,
		}
	end

	function tab:AddSection(text)
		local holder = styleSectionContainer(self.Page)
		holder.Size = UDim2.new(1, 0, 0, 28)
		local lbl = addLabel(holder, text)
		lbl.TextSize = 15
		return holder
	end

	return tab
end

local function makeWindow(titleText)
	local window = {}
	window.CurrentTab = nil
	window.Tabs = {}

	function window:SetTitle(newTitle)
		Title.Text = tostring(newTitle or DEFAULT_TITLE)
	end

	function window:Show()
		setUiVisible(true)
	end

	function window:Hide()
		setUiVisible(false)
	end

	function window:CreateTab(name)
		name = tostring(name or ("Tab " .. tostring(#self.Tabs + 1)))
		local page = makePage(name)
		local button = createTabButton(name, #self.Tabs + 1)
		local tab = makeTabApi(self, name, page, button)

		table.insert(self.Tabs, tab)

		registerConnection(button.MouseButton1Click:Connect(function()
			tab:SetSelected()
		end))

		if #self.Tabs == 1 then
			tab:SetSelected()
		end

		return tab
	end

	window.AddTab = window.CreateTab

	local defaultTab = window:CreateTab("Main")

	function window:_getTab()
		return self.CurrentTab or defaultTab
	end

	function window:AddLabel(...)
		return self:_getTab():AddLabel(...)
	end
	function window:AddButton(...)
		return self:_getTab():AddButton(...)
	end
	function window:AddToggle(...)
		return self:_getTab():AddToggle(...)
	end
	function window:AddSlider(...)
		return self:_getTab():AddSlider(...)
	end
	function window:AddDropdown(...)
		return self:_getTab():AddDropdown(...)
	end
	function window:AddTextbox(...)
		return self:_getTab():AddTextbox(...)
	end
	function window:AddKeybind(...)
		return self:_getTab():AddKeybind(...)
	end
	function window:AddSection(...)
		return self:_getTab():AddSection(...)
	end

	function window:Destroy()
		resetAllToggles()
		disconnectAll()
		ScreenGui:Destroy()
	end

	return setmetatable(window, Library)
end

function Library:CreateWindow(titleText)
	if titleText and tostring(titleText) ~= "" then
		Title.Text = tostring(titleText)
	else
		Title.Text = DEFAULT_TITLE
	end

	LibraryState.Window = makeWindow(titleText or DEFAULT_TITLE)

	return LibraryState.Window
end

function Library:SetTitle(newTitle)
	Title.Text = tostring(newTitle or DEFAULT_TITLE)
end

function Library:Hide()
	setUiVisible(false)
end

function Library:Show()
	setUiVisible(true)
end

function Library:Destroy()
	if LibraryState.Window then
		LibraryState.Window:Destroy()
	else
		ScreenGui:Destroy()
	end
end

