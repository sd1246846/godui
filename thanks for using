local function makeCanvasUpdater(scroller)
	local layout = scroller:FindFirstChildOfClass("UIListLayout")
	if not layout then
		layout = listLayout(scroller, Enum.SortOrder.LayoutOrder, 4)
	end
	local function update()
		scroller.CanvasSize = UDim2.new(0, 0, 0, layout.AbsoluteContentSize.Y + 8)
	end
	layout:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(update)
	update()
end

