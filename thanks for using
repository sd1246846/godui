local function makeTabApi(window, tabName, page, tabButton)
	local tab = {}
	tab.__index = tab

	tab.Name = tabName
	tab.Page = page
	tab.Button = tabButton
	tab.Window = window

	function tab:SetSelected()
		for _, child in ipairs(ContentFrame:GetChildren()) do
			if child:IsA("Frame") and child.Name:sub(-5) == "_page" then
				child.Visible = false
			end
		end
		for _, child in ipairs(TabsFrame:GetChildren()) do
			if child:IsA("TextButton") then
				child.BackgroundColor3 = Colors.Top
			end
		end
		self.Page.Visible = true
		self.Button.BackgroundColor3 = Colors.Accent
		window.CurrentTab = self
		makeCanvasUpdater(ContentFrame)
	end

	function tab:AddLabel(text)
		local holder = styleSectionContainer(self.Page)
		local lbl = addLabel(holder, text)
		holder.Size = UDim2.new(1, 0, 0, 28)
		return lbl
	end

	function tab:AddButton(opts)
		opts = opts or {}
		local holder = styleSectionContainer(self.Page)
		local btn = create("TextButton", {
			Font = Enum.Font.FredokaOne,
			Text = tostring(opts.text or "Button"),
			TextColor3 = Colors.Text,
			TextSize = 15,
			BackgroundColor3 = Colors.Main,
			BorderSizePixel = 0,
			Size = UDim2.new(1, 0, 0, 30),
			Parent = holder,
		})
		corner(btn)
		registerConnection(btn.MouseButton1Click:Connect(function()
			safeCall(opts.callback)
		end))
		return {
			Button = btn,
			SetText = function(_, t)
				btn.Text = tostring(t)
			end,
		}
	end

	function tab:AddToggle(opts)
		opts = opts or {}
		local state = opts.state or false
		local holder = styleSectionContainer(self.Page)
		local root = styleControlFrame(holder, 32)

		local label = create("TextLabel", {
			BackgroundTransparency = 1,
			Size = UDim2.new(1, -40, 1, 0),
			Position = UDim2.new(0, 8, 0, 0),
			Font = Enum.Font.FredokaOne,
			Text = tostring(opts.text or "Toggle"),
			TextColor3 = Colors.Text,
			TextSize = 14,
			TextXAlignment = Enum.TextXAlignment.Left,
			Parent = root,
		})

		local switch = create("TextButton", {
			Text = "",
			BackgroundColor3 = state and Color3.fromRGB(60, 160, 60) or Color3.fromRGB(70, 70, 70),
			BorderSizePixel = 0,
			Size = UDim2.new(0, 26, 0, 14),
			Position = UDim2.new(1, -32, 0.5, -7),
			Parent = root,
		})
		corner(switch, UDim.new(1, 0))

		local knob = create("Frame", {
			BackgroundColor3 = Colors.Text,
			BorderSizePixel = 0,
			Size = UDim2.new(0, 10, 0, 10),
			Position = state and UDim2.new(1, -12, 0.5, -5) or UDim2.new(0, 2, 0.5, -5),
			Parent = switch,
		})
		corner(knob, UDim.new(1, 0))

		local toggle = {}
		toggle.State = state
		toggle.Set = function(_, newState, silent)
			newState = not not newState
			toggle.State = newState
			TweenService:Create(switch, TweenInfo.new(0.15), {
				BackgroundColor3 = newState and Color3.fromRGB(60, 160, 60) or Color3.fromRGB(70, 70, 70)
			}):Play()
			TweenService:Create(knob, TweenInfo.new(0.15), {
				Position = newState and UDim2.new(1, -12, 0.5, -5) or UDim2.new(0, 2, 0.5, -5)
			}):Play()
			if not silent then
				safeCall(opts.callback, newState)
			end
		end

		registerConnection(root.InputBegan:Connect(function(input)
			if input.UserInputType == Enum.UserInputType.MouseButton1 then
				toggle:Set(not toggle.State)
			end
		end))
		registerConnection(switch.MouseButton1Click:Connect(function()
			toggle:Set(not toggle.State)
		end))

		table.insert(LibraryState.AllToggles, toggle)
		return toggle
	end

	function tab:AddSlider(opts)
		opts = opts or {}
		local minv = tonumber(opts.min) or 0
		local maxv = tonumber(opts.max) or 100
		local value = clamp(tonumber(opts.value) or minv, minv, maxv)

		local holder = styleSectionContainer(self.Page)
		holder.Size = UDim2.new(1, 0, 0, 44)

		local label = create("TextLabel", {
			BackgroundTransparency = 1,
			Size = UDim2.new(1, -10, 0, 16),
			Position = UDim2.new(0, 5, 0, 2),
			Font = Enum.Font.FredokaOne,
			Text = tostring(opts.text or "Slider") .. " : " .. tostring(round(value)),
			TextColor3 = Colors.Text,
			TextSize = 13,
			TextXAlignment = Enum.TextXAlignment.Left,
			Parent = holder,
		})

		local bar = create("Frame", {
			BackgroundColor3 = Color3.fromRGB(60, 60, 60),
			BorderSizePixel = 0,
			Position = UDim2.new(0, 5, 0, 24),
			Size = UDim2.new(1, -10, 0, 10),
			Parent = holder,
		})
		corner(bar, UDim.new(1, 0))

		local fill = create("Frame", {
			BackgroundColor3 = Color3.fromRGB(100, 100, 100),
			BorderSizePixel = 0,
			Size = UDim2.new((value - minv) / math.max(1, maxv - minv), 0, 1, 0),
			Parent = bar,
		})
		corner(fill, UDim.new(1, 0))

		local draggingSlider = false

		local function setValue(newValue, silent)
			value = clamp(newValue, minv, maxv)
			local alpha = (value - minv) / math.max(1, maxv - minv)
			fill.Size = UDim2.new(alpha, 0, 1, 0)
			label.Text = tostring(opts.text or "Slider") .. " : " .. tostring(round(value))
			if not silent then
				safeCall(opts.callback, value)
			end
		end

		local function updateFromInput(input)
			local x = clamp((input.Position.X - bar.AbsolutePosition.X) / math.max(1, bar.AbsoluteSize.X), 0, 1)
			setValue(minv + ((maxv - minv) * x))
		end

		registerConnection(bar.InputBegan:Connect(function(input)
			if input.UserInputType == Enum.UserInputType.MouseButton1 then
				draggingSlider = true
				updateFromInput(input)
			end
		end))

		registerConnection(bar.InputEnded:Connect(function(input)
			if input.UserInputType == Enum.UserInputType.MouseButton1 then
				draggingSlider = false
			end
		end))

		registerConnection(UserInputService.InputChanged:Connect(function(input)
			if draggingSlider and input.UserInputType == Enum.UserInputType.MouseMovement then
				updateFromInput(input)
			end
		end))

		setValue(value, true)

		return {
			SetValue = function(_, newValue)
				setValue(newValue)
			end,
			GetValue = function()
				return value
			end,
		}
	end

	function tab:AddDropdown(opts)
		opts = opts or {}
		local items = opts.options or {}
		local selected = opts.value or opts.default or items[1]

		local holder = styleSectionContainer(self.Page)
		holder.Size = UDim2.new(1, 0, 0, 34)

		local top = create("TextButton", {
			Font = Enum.Font.FredokaOne,
			Text = tostring(opts.text or "Dropdown") .. " : " .. tostring(selected or "nil"),
			TextColor3 = Colors.Text,
			TextSize = 14,
			TextXAlignment = Enum.TextXAlignment.Left,
			BackgroundColor3 = Colors.Main,
			BorderSizePixel = 0,
			Size = UDim2.new(1, 0, 0, 30),
			Parent = holder,
		})
		corner(top)

		local listHolder = create("Frame", {
			BackgroundTransparency = 1,
			BorderSizePixel = 0,
			Size = UDim2.new(1, 0, 0, 0),
			AutomaticSize = Enum.AutomaticSize.Y,
			Visible = false,
			Parent = holder,
		})

		local itemLayout = listLayout(listHolder, Enum.SortOrder.LayoutOrder, 3)
		itemLayout.HorizontalAlignment = Enum.HorizontalAlignment.Center

		local open = false
		local function refreshTitle()
			top.Text = tostring(opts.text or "Dropdown") .. " : " .. tostring(selected or "nil")
		end

		local function choose(value)
			selected = value
			refreshTitle()
			safeCall(opts.callback, value)
		end

		for i, item in ipairs(items) do
			local option = create("TextButton", {
				Font = Enum.Font.FredokaOne,
				Text = tostring(item),
				TextColor3 = Colors.Text,
				TextSize = 13,
				BackgroundColor3 = Colors.Top,
				BorderSizePixel = 0,
				Size = UDim2.new(1, 0, 0, 24),
				LayoutOrder = i,
				Parent = listHolder,
			})
			corner(option)
			registerConnection(option.MouseButton1Click:Connect(function()
				choose(item)
				open = false
				listHolder.Visible = false
				holder.Size = UDim2.new(1, 0, 0, 34)
			end))
		end

		registerConnection(top.MouseButton1Click:Connect(function()
			open = not open
			listHolder.Visible = open
			holder.Size = open and UDim2.new(1, 0, 0, 34 + (#items * 27)) or UDim2.new(1, 0, 0, 34)
		end))

		refreshTitle()
		safeCall(opts.callback, selected)

		return {
			SetValue = function(_, v)
				choose(v)
			end,
			GetValue = function()
				return selected
			end,
		}
	end

	function tab:AddTextbox(opts)
		opts = opts or {}
		local holder = styleSectionContainer(self.Page)
		holder.Size = UDim2.new(1, 0, 0, 40)

		local box = create("TextBox", {
			Font = Enum.Font.FredokaOne,
			Text = tostring(opts.default or ""),
			PlaceholderText = tostring(opts.placeholder or "Enter text"),
			TextColor3 = Colors.Text,
			PlaceholderColor3 = Colors.Muted,
			TextSize = 13,
			BackgroundColor3 = Colors.Main,
			BorderSizePixel = 0,
			ClearTextOnFocus = false,
			Size = UDim2.new(1, 0, 0, 30),
			Parent = holder,
		})
		corner(box)

		registerConnection(box.FocusLost:Connect(function(enterPressed)
			if enterPressed then
				safeCall(opts.callback, box.Text)
			end
		end))

		return {
			GetText = function()
				return box.Text
			end,
			SetText = function(_, t)
				box.Text = tostring(t)
			end,
		}
	end

