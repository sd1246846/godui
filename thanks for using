-- ── AddSection ──────────────────────────────────────────────
function Tab:AddSection(opts)
    opts = opts or {}
    local row = Instance.new("Frame")
    row.BackgroundTransparency = 1
    row.Size = UDim2.new(1,0,0,18)
    row.Parent = self._cf

    -- Thin line left
    local lineL = Instance.new("Frame")
    lineL.BackgroundColor3 = T.border
    lineL.BorderSizePixel  = 0
    lineL.AnchorPoint      = Vector2.new(0,0.5)
    lineL.Position         = UDim2.new(0,0,0.5,0)
    lineL.Size             = UDim2.new(0,8,0,1)
    lineL.Parent = row

    -- Label
    local txt = Instance.new("TextLabel")
    txt.BackgroundTransparency = 1
    txt.Font     = Enum.Font.GothamBold
    txt.Text     = string.upper(opts.text or "section")
    txt.TextSize = 9
    txt.TextColor3 = T.textMut
    txt.TextXAlignment = Enum.TextXAlignment.Left
    txt.AnchorPoint = Vector2.new(0,0.5)
    txt.Position    = UDim2.new(0,14,0.5,0)
    txt.Size        = UDim2.new(1,-14,1,0)
    txt.Parent = row

    -- Thin line right (after text — we cheat with a right-anchored frame)
    local lineR = Instance.new("Frame")
    lineR.BackgroundColor3 = T.border
    lineR.BorderSizePixel  = 0
    lineR.AnchorPoint      = Vector2.new(1,0.5)
    lineR.Position         = UDim2.new(1,0,0.5,0)
    lineR.Size             = UDim2.new(0,0,0,1)   -- width set dynamically below
    lineR.Parent = row

    -- We can't measure text easily in Lua before rendering,
    -- so just make it a trailing line of fixed width to keep it clean.
