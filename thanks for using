        selLbl.Text=tostring(selected)..(isOpen and " ▴" or " ▾")
    end)
    header.MouseEnter:Connect(function() tw(header,0.1,{BackgroundColor3=T.hover}) end)
    header.MouseLeave:Connect(function() tw(header,0.1,{BackgroundColor3=T.card}) end)

    return {
        SetValue=function(_,v) selected=v; selLbl.Text=tostring(v).." ▾" end,
        GetValue=function(_) return selected end,
        SetOptions=function(_,newOpts)
            options=newOpts
            for _,ch in ipairs(drop:GetChildren()) do if ch:IsA("TextButton") then ch:Destroy() end end
            for _,o in ipairs(newOpts) do addOpt(o) end
        end,
    }
