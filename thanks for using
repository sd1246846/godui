local function SURMKD_fake_script()
    local script = Instance.new("LocalScript")
    script.Parent = Converted["_godlib"]
    local UIS2 = game:GetService("UserInputService")
    local MF   = script.Parent:WaitForChild("god lib")
    local TB1  = MF:WaitForChild("title")
    local TB2  = MF:WaitForChild("dragbutton")
    local TB3  = MF.Parent:WaitForChild("reopen")
    local dragging, dragInput, dragStart, startPos = false, nil, nil, nil
    local function update(i)
        local d = Vector2.new(i.Position.X,i.Position.Y) - dragStart
        MF.Position = UDim2.new(startPos.X.Scale,startPos.X.Offset+d.X,startPos.Y.Scale,startPos.Y.Offset+d.Y)
    end
    local function btf(gui)
        local mx = 0
        for _,v in ipairs(gui.Parent:GetChildren()) do if v:IsA("GuiObject") and v.ZIndex>mx then mx=v.ZIndex end end
        if gui.ZIndex<=mx then
            local diff=(mx+1)-gui.ZIndex gui.ZIndex=mx+1
            for _,c in ipairs(gui:GetDescendants()) do if c:IsA("GuiObject") then c.ZIndex=c.ZIndex+diff end end
        end
    end
    local function hb(i)
        if i.UserInputType==Enum.UserInputType.MouseButton1 or i.UserInputType==Enum.UserInputType.Touch then
            dragging=true dragStart=Vector2.new(i.Position.X,i.Position.Y) startPos=MF.Position btf(MF)
            i.Changed:Connect(function() if i.UserInputState==Enum.UserInputState.End then dragging=false end end)
        end
    end
    local function hc(i) if i.UserInputType==Enum.UserInputType.MouseMovement or i.UserInputType==Enum.UserInputType.Touch then dragInput=i end end
    TB1.InputBegan:Connect(hb) TB1.InputChanged:Connect(hc)
    TB2.InputBegan:Connect(hb) TB2.InputChanged:Connect(hc)
    TB3.InputBegan:Connect(hb) TB3.InputChanged:Connect(hc)
    UIS2.InputChanged:Connect(function(i) if i==dragInput and dragging then update(i) end end)
    UIS2.InputEnded:Connect(function(i)
        if i.UserInputType==Enum.UserInputType.MouseButton1 or i.UserInputType==Enum.UserInputType.Touch then dragging=false dragInput=nil end
    end)
end
