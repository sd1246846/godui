-- ----------------------------------------------------------------
-- ICON SYSTEM
-- ----------------------------------------------------------------
local _iconCache = nil
local function GetIcon(name, source)
    source = source or "Lucide"
    if source == "Custom" then return {id=tonumber(tostring(name)), raw=true} end
    if source ~= "Lucide" then return nil end
    if RS:IsStudio() then return {id=10723434557,imageRectSize=Vector2.new(48,48),imageRectOffset=Vector2.new(0,0)} end
    if not _iconCache then
        local ok,res = pcall(function()
            return loadstring(game:HttpGet("https://raw.githubusercontent.com/latte-soft/lucide-roblox/refs/heads/master/lib/Icons.luau"))()
        end)
        _iconCache = ok and res or {}
    end
    local sized = _iconCache["48px"]; if not sized then return nil end
    local key = string.match(string.lower(name),"^%s*(.-)%s*$")
    local r = sized[key]; if not r then return nil end
    return {id=r[1], imageRectSize=Vector2.new(r[2][1],r[2][2]), imageRectOffset=Vector2.new(r[3][1],r[3][2])}
end
local function ApplyIcon(img, asset)
    if not asset then return end
    img.Image = "rbxassetid://"..tostring(asset.id)
    if asset.raw then img.ImageRectSize=Vector2.new(0,0); img.ImageRectOffset=Vector2.new(0,0)
    else img.ImageRectSize=asset.imageRectSize; img.ImageRectOffset=asset.imageRectOffset end
end

