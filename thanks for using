local dragging = false
local dragInput
local dragStart
local startPos

local function bringToFront(gui)
	local maxZ = 0
	for _, v in ipairs(gui.Parent:GetChildren()) do
		if v:IsA("GuiObject") and v.ZIndex > maxZ then
			maxZ = v.ZIndex
		end
	end
	if gui.ZIndex <= maxZ then
		local diff = (maxZ + 1) - gui.ZIndex
		gui.ZIndex = maxZ + 1
		for _, child in ipairs(gui:GetDescendants()) do
			if child:IsA("GuiObject") then
				child.ZIndex = child.ZIndex + diff
			end
		end
	end
end

local function updateDrag(input, target)
	local inputPos = Vector2.new(input.Position.X, input.Position.Y)
	local delta = inputPos - dragStart
	target.Position = UDim2.new(
		startPos.X.Scale,
		startPos.X.Offset + delta.X,
		startPos.Y.Scale,
		startPos.Y.Offset + delta.Y
	)
end

local function bindDragInput(targetObject)
	local function handleInputBegan(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
			dragging = true
			dragStart = Vector2.new(input.Position.X, input.Position.Y)
			startPos = targetObject.Position
			bringToFront(targetObject)
			input.Changed:Connect(function()
				if input.UserInputState == Enum.UserInputState.End then
					dragging = false
				end
			end)
		end
	end

	local function handleInputChanged(input)
		if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then
			dragInput = input
		end
	end

	return handleInputBegan, handleInputChanged
end

local mainBegan, mainChanged = bindDragInput(MainFrame)
Title.InputBegan:Connect(mainBegan)
Title.InputChanged:Connect(mainChanged)
DragButton.InputBegan:Connect(mainBegan)
DragButton.InputChanged:Connect(mainChanged)

local reopenBegan, reopenChanged = bindDragInput(ReopenButton)
ReopenButton.InputBegan:Connect(reopenBegan)
ReopenButton.InputChanged:Connect(reopenChanged)

UserInputService.InputChanged:Connect(function(input)
	if input == dragInput and dragging then
		if MainFrame.Visible then
			updateDrag(input, MainFrame)
		else
			updateDrag(input, ReopenButton)
		end
	end
end)

UserInputService.InputEnded:Connect(function(input)
	if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
		dragging = false
		dragInput = nil
	end
end)

local LibraryState = {
	Window = nil,
	AllToggles = {},
	AllConnections = {},
	Closed = false,
}

local function registerConnection(conn)
	table.insert(LibraryState.AllConnections, conn)
	return conn
end

local function disconnectAll()
	for _, conn in ipairs(LibraryState.AllConnections) do
		pcall(function()
			conn:Disconnect()
		end)
	end
	table.clear(LibraryState.AllConnections)
end

