-- ================================================================
-- DRAG UTILITIES
-- ================================================================
local function bringToFront(gui)
    local mx = 0
    for _,v in ipairs(gui.Parent:GetChildren()) do
        if v:IsA("GuiObject") and v.ZIndex > mx then mx = v.ZIndex end
    end
    if gui.ZIndex <= mx then
        local diff = mx+1 - gui.ZIndex
        gui.ZIndex = mx+1
        for _,ch in ipairs(gui:GetDescendants()) do
            if ch:IsA("GuiObject") then ch.ZIndex = ch.ZIndex+diff end
        end
    end
end

-- Drag for the main window (title + dragstrip handles)
local function wireMainDrag(mainFrame)
    local TB1 = mainFrame:WaitForChild("title")
    local TB2 = mainFrame:WaitForChild("dragbutton")
    local dragging, dragInput, dragStart, startPos = false,nil,nil,nil
    local function update(i)
        if not dragging then return end
        local d = Vector2.new(i.Position.X,i.Position.Y) - dragStart
        mainFrame.Position = UDim2.new(startPos.X.Scale,startPos.X.Offset+d.X,startPos.Y.Scale,startPos.Y.Offset+d.Y)
    end
    local function hb(i)
        if i.UserInputType==Enum.UserInputType.MouseButton1 or i.UserInputType==Enum.UserInputType.Touch then
            dragging=true; dragStart=Vector2.new(i.Position.X,i.Position.Y); startPos=mainFrame.Position
            bringToFront(mainFrame)
        end
    end
    local function hc(i)
        if i.UserInputType==Enum.UserInputType.MouseMovement or i.UserInputType==Enum.UserInputType.Touch then dragInput=i end
    end
    TB1.InputBegan:Connect(hb); TB1.InputChanged:Connect(hc)
    TB2.InputBegan:Connect(hb); TB2.InputChanged:Connect(hc)
    UIS.InputChanged:Connect(function(i) if i==dragInput and dragging then update(i) end end)
    UIS.InputEnded:Connect(function(i)
        if i.UserInputType==Enum.UserInputType.MouseButton1 or i.UserInputType==Enum.UserInputType.Touch then
            dragging=false; dragInput=nil
        end
    end)
end

-- Drag for the reopen pill  — THRESHOLD-BASED so click still works
-- Only counts as a drag if the mouse moves > THRESH pixels.
-- MouseButton1Click only fires if no drag occurred.
local function wireReopenDrag(pill, onClickFn)
    local THRESH    = 4
    local dragging  = false
    local hasDragged= false
    local dragInput = nil
    local dragStart = nil
    local startPos  = nil

    local function screenSize()
        local sg = pill.Parent
        if sg and sg:IsA("ScreenGui") then return sg.AbsoluteSize end
        return game:GetService("Workspace").CurrentCamera.ViewportSize
    end

    -- Convert pill to pure-offset position so drag math stays clean
    local function convertPos()
        local ap = pill.AbsolutePosition
        pill.Position = UDim2.new(0,ap.X,0,ap.Y)
    end

    pill.InputBegan:Connect(function(i)
        if i.UserInputType==Enum.UserInputType.MouseButton1 or i.UserInputType==Enum.UserInputType.Touch then
            convertPos()
            dragging  = true
            hasDragged= false
            dragStart = Vector2.new(i.Position.X,i.Position.Y)
            startPos  = pill.Position
        end
    end)

    pill.InputChanged:Connect(function(i)
        if i.UserInputType==Enum.UserInputType.MouseMovement or i.UserInputType==Enum.UserInputType.Touch then
            dragInput = i
        end
    end)

    UIS.InputChanged:Connect(function(i)
        if not dragging then return end
        if i~=dragInput then return end
        local delta = Vector2.new(i.Position.X,i.Position.Y) - dragStart
        if delta.Magnitude >= THRESH then
            hasDragged = true
            local sc = screenSize()
            local sz = pill.AbsoluteSize
            local nx = math.clamp(startPos.X.Offset+delta.X, 0, sc.X-sz.X)
            local ny = math.clamp(startPos.Y.Offset+delta.Y, 0, sc.Y-sz.Y)
            pill.Position = UDim2.new(0,nx,0,ny)
        end
    end)

    UIS.InputEnded:Connect(function(i)
        if i.UserInputType==Enum.UserInputType.MouseButton1 or i.UserInputType==Enum.UserInputType.Touch then
            dragging = false; dragInput = nil
        end
    end)

    -- Only reopen when it was a tap, not a drag
    pill.MouseButton1Click:Connect(function()
        if hasDragged then hasDragged=false; return end
        onClickFn()
    end)
end

