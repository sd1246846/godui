        local dc=false
        tr.InputBegan:Connect(function(inp)
            if inp.UserInputType==Enum.UserInputType.MouseButton1 then
                dc=true; local p=math.clamp((inp.Position.X-tr.AbsolutePosition.X)/tr.AbsoluteSize.X,0,1)
                ch[sd.k]=math.round(p*255); fi.Size=UDim2.new(p,0,1,0); kn.Position=UDim2.new(p,0,0.5,0)
                vl.Text=tostring(ch[sd.k]); refresh()
            end
        end)
        UIS.InputChanged:Connect(function(inp)
            if dc and inp.UserInputType==Enum.UserInputType.MouseMovement then
                local p=math.clamp((inp.Position.X-tr.AbsolutePosition.X)/tr.AbsoluteSize.X,0,1)
                ch[sd.k]=math.round(p*255); fi.Size=UDim2.new(p,0,1,0); kn.Position=UDim2.new(p,0,0.5,0)
                vl.Text=tostring(ch[sd.k]); refresh()
            end
        end)
        UIS.InputEnded:Connect(function(inp)
            if inp.UserInputType==Enum.UserInputType.MouseButton1 then dc=false end
        end)
    end

    local open=false
    row.MouseButton1Click:Connect(function()
        open=not open; panel.Visible=open
        row.Size=open and UDim2.new(1,-8,0,128) or UDim2.new(1,-8,0,26)
    end)
    row.MouseEnter:Connect(function() if not open then tw(row,0.1,{BackgroundColor3=T.hover}) end end)
    row.MouseLeave:Connect(function() if not open then tw(row,0.1,{BackgroundColor3=T.card}) end end)

    return {
        GetColor=function(_) return current end,
        SetColor=function(_,c)
            current=c; swatch.BackgroundColor3=c
            ch.r=math.round(c.R*255); ch.g=math.round(c.G*255); ch.b=math.round(c.B*255)
        end,
    }
end

-- ─── KEYBIND ────────────────────────────────────────────────
-- Row is a TextButton — no invisible overlay needed
function Tab:AddKeybind(opts)
    opts=opts or {}
    local cb=opts.callback or function() end
    local currentKey=opts.key
    local id=tostring(math.random(1e9))

    local row=Instance.new("TextButton")
    row.Text=""; row.AutoButtonColor=false
    row.BackgroundColor3=T.card; row.BorderSizePixel=0
    row.Size=UDim2.new(1,-8,0,26); row.LayoutOrder=nextOrder(self)
    crn(row,4); row.Parent=self._cf

    local lbl=newLabel(row, opts.text or "Keybind",12,T.text)
    lbl.Size=UDim2.new(0.55,0,1,0); lbl.Position=UDim2.new(0,8,0,0)

    local badge=Instance.new("TextButton")
    badge.Font=Enum.Font.GothamSemibold; badge.Text=keyName(currentKey)
    badge.TextSize=10; badge.TextColor3=T.accent; badge.BackgroundColor3=T.bg
    badge.BorderSizePixel=0; badge.AnchorPoint=Vector2.new(1,0.5)
    badge.Position=UDim2.new(1,-8,0.5,0); badge.Size=UDim2.new(0,54,0,16)
    badge.AutoButtonColor=false; badge.ZIndex=3
    crn(badge,3); badge.Parent=row

    local listening=false
    local function setL(v)
        listening=v
        if v then
            badge.Text="…"; badge.TextColor3=T.danger
            tw(badge,0.1,{BackgroundColor3=Color3.fromRGB(50,28,28)})
        else
            badge.Text=keyName(currentKey); badge.TextColor3=T.accent
            tw(badge,0.1,{BackgroundColor3=T.bg})
        end
    end

    badge.MouseButton1Click:Connect(function() setL(not listening) end)

    UIS.InputBegan:Connect(function(inp,gp)
        if listening then
            if inp.UserInputType==Enum.UserInputType.Keyboard then
                currentKey=(inp.KeyCode==Enum.KeyCode.Escape) and nil or inp.KeyCode
                for _,b in ipairs(_binds) do if b.id==id then b.key=currentKey; break end end
                setL(false)
            end
            return
        end
        if gp then return end
        if inp.UserInputType==Enum.UserInputType.Keyboard and currentKey and inp.KeyCode==currentKey then
            pcall(cb, currentKey)
        end
    end)

    table.insert(_binds, {id=id, key=currentKey, fn=function() end})

    row.MouseEnter:Connect(function() tw(row,0.1,{BackgroundColor3=T.hover}) end)
    row.MouseLeave:Connect(function() tw(row,0.1,{BackgroundColor3=T.card}) end)

    return {
        GetKey=function(_) return currentKey end,
        SetKey=function(_,k)
            currentKey=k; badge.Text=keyName(k)
            for _,b in ipairs(_binds) do if b.id==id then b.key=k; break end end
        end,
        Unbind=function(_)
            currentKey=nil; badge.Text="—"
            for _,b in ipairs(_binds) do if b.id==id then b.key=nil; break end end
        end,
    }
end

-- ================================================================
-- WINDOW OBJECT
-- ================================================================
local Window={}; Window.__index=Window

function Window:CreateTab(name, icon, iconSource)
    local tab=setmetatable({},Tab); tab._win=self; tab._order=0

    -- sidebar button
    local btn=Instance.new("TextButton")
    btn.BackgroundColor3=T.bg; btn.BorderSizePixel=0
    btn.Size=UDim2.new(1,-4,0,40); btn.Text=""; btn.AutoButtonColor=false
    crn(btn,4); btn.Parent=C["_tabsframe"]; tab._btn=btn

    -- active indicator bar (left edge)
    local bar=Instance.new("Frame"); bar.BackgroundColor3=T.accent; bar.BorderSizePixel=0
    bar.AnchorPoint=Vector2.new(0,0.5); bar.Position=UDim2.new(0,0,0.5,0)
    bar.Size=UDim2.new(0,2,0.5,0); bar.Visible=false; crn(bar,1); bar.Parent=btn; tab._bar=bar

    if icon then
        local img=Instance.new("ImageLabel"); img.BackgroundTransparency=1
        img.AnchorPoint=Vector2.new(0.5,0.5); img.Position=UDim2.new(0.5,0,0.37,0)
        img.Size=UDim2.new(0,16,0,16); img.ImageColor3=T.muted; img.ScaleType=Enum.ScaleType.Fit
        img.Parent=btn; tab._img=img
        task.spawn(function()
            local asset=GetIcon(icon,iconSource or "Lucide")
            if asset then ApplyIcon(img,asset)
            else img:Destroy(); tab._img=nil end
        end)
        local nl=Instance.new("TextLabel"); nl.BackgroundTransparency=1; nl.Font=Enum.Font.Gotham
        nl.Text=string.sub(name,1,5); nl.TextSize=8; nl.TextColor3=T.muted
        nl.TextXAlignment=Enum.TextXAlignment.Center; nl.AnchorPoint=Vector2.new(0.5,1)
        nl.Position=UDim2.new(0.5,0,1,-3); nl.Size=UDim2.new(1,-2,0,11); nl.Parent=btn; tab._nl=nl
    else
        local tl=Instance.new("TextLabel"); tl.BackgroundTransparency=1; tl.Font=Enum.Font.GothamSemibold
        tl.Text=string.sub(name,1,4); tl.TextSize=10; tl.TextColor3=T.muted
        tl.TextXAlignment=Enum.TextXAlignment.Center; tl.AnchorPoint=Vector2.new(0.5,0.5)
        tl.Position=UDim2.new(0.5,0,0.5,0); tl.Size=UDim2.new(1,-4,1,-4); tl.TextWrapped=true
        tl.Parent=btn; tab._tl=tl
    end

    -- per-tab content scrolling frame
    local cf=Instance.new("ScrollingFrame")
    cf.BackgroundTransparency=1; cf.BorderSizePixel=0
    cf.ScrollBarThickness=2; cf.ScrollBarImageColor3=T.accent; cf.ScrollBarImageTransparency=0.5
    cf.Position=UDim2.new(0,0,0,0); cf.Size=UDim2.new(1,0,1,0)
    cf.Visible=(#self._tabs==0)
    cf.Parent=C["_frame"]; tab._cf=cf

    local lay=newListLayout(cf, 3)
    newPadding(cf, 4,4,4,4)
    lay:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function()
        cf.CanvasSize=UDim2.new(0,0,0,lay.AbsoluteContentSize.Y+8)
    end)

    -- activate / deactivate
    local function deactivateAll()
        for _,t in ipairs(self._tabs) do
            t._cf.Visible=false; tw(t._btn,0.14,{BackgroundColor3=T.bg}); t._bar.Visible=false
            if t._img then tw(t._img,0.14,{ImageColor3=T.muted}) end
            if t._nl  then tw(t._nl, 0.14,{TextColor3=T.muted}) end
            if t._tl  then tw(t._tl, 0.14,{TextColor3=T.muted}) end
        end
    end
    local function activateThis()
        deactivateAll(); cf.Visible=true; bar.Visible=true
        tw(btn,0.14,{BackgroundColor3=T.card})
        if tab._img then tw(tab._img,0.14,{ImageColor3=T.text}) end
        if tab._nl  then tw(tab._nl, 0.14,{TextColor3=T.text}) end
        if tab._tl  then tw(tab._tl, 0.14,{TextColor3=T.text}) end
        self._active=tab
    end

    btn.MouseButton1Click:Connect(activateThis)
    btn.MouseEnter:Connect(function() if self._active~=tab then tw(btn,0.1,{BackgroundColor3=T.panel}) end end)
    btn.MouseLeave:Connect(function() if self._active~=tab then tw(btn,0.1,{BackgroundColor3=T.bg}) end end)

    if #self._tabs==0 then
        btn.BackgroundColor3=T.card; bar.Visible=true
        if tab._img then tab._img.ImageColor3=T.text end
        if tab._nl  then tab._nl.TextColor3=T.text end
        if tab._tl  then tab._tl.TextColor3=T.text end
        self._active=tab
    end

    table.insert(self._tabs,tab)
    task.defer(function()
        local l=C["_tabsframe"]:FindFirstChildOfClass("UIListLayout")
        if l then C["_tabsframe"].CanvasSize=UDim2.new(0,0,0,l.AbsoluteContentSize.Y+4) end
    end)

    return tab
end

function Window:_def()
    if not self._defaultTab then self._defaultTab=self:CreateTab("Main") end
    return self._defaultTab
end
function Window:AddSection(o)      return self:_def():AddSection(o) end
function Window:AddLabel(o)        return self:_def():AddLabel(o) end
function Window:AddButton(o)       return self:_def():AddButton(o) end
function Window:AddToggle(o)       return self:_def():AddToggle(o) end
function Window:AddSlider(o)       return self:_def():AddSlider(o) end
function Window:AddDropdown(o)     return self:_def():AddDropdown(o) end
function Window:AddTextbox(o)      return self:_def():AddTextbox(o) end
function Window:AddColorPicker(o)  return self:_def():AddColorPicker(o) end
function Window:AddKeybind(o)      return self:_def():AddKeybind(o) end

