end

-- ─── SLIDER ─────────────────────────────────────────────────
function Tab:AddSlider(opts)
    opts = opts or {}
    local cb       = opts.callback or function() end
    local mn       = opts.min or 0
    local mx       = opts.max or 100
    local suffix   = opts.suffix or ""
    local decimals = opts.decimals or 0
    local val      = math.clamp(opts.value or opts.default or mn, mn, mx)

    local row = Instance.new("Frame")
    row.BackgroundColor3=T.card; row.BorderSizePixel=0
    row.Size=UDim2.new(1,-8,0,40); row.LayoutOrder=nextOrder(self)
    crn(row,4); row.Parent=self._cf
    newPadding(row,6,6,8,8)

    -- name + value line
    local topF=Instance.new("Frame"); topF.BackgroundTransparency=1
    topF.Size=UDim2.new(1,0,0,14); topF.Parent=row
    local nameLbl = newLabel(topF, opts.text or "Slider", 11, T.text)
    nameLbl.Size=UDim2.new(0.6,0,1,0)
    local valLbl = newLabel(topF, "", 11, T.accent, Enum.TextXAlignment.Right)
    valLbl.Size=UDim2.new(0.4,0,1,0); valLbl.Position=UDim2.new(0.6,0,0,0)

    -- track
    local track=Instance.new("Frame")
    track.BackgroundColor3=T.bg; track.BorderSizePixel=0
    track.Size=UDim2.new(1,0,0,5); track.Position=UDim2.new(0,0,0,20)
    crn(track,3); track.Parent=row

    local fill=Instance.new("Frame")
    fill.BackgroundColor3=T.accent; fill.BorderSizePixel=0
    fill.Size=UDim2.new(0,0,1,0); crn(fill,3); fill.Parent=track

    local knob=Instance.new("Frame")
    knob.AnchorPoint=Vector2.new(0.5,0.5); knob.Size=UDim2.new(0,9,0,9)
    knob.BackgroundColor3=Color3.fromRGB(255,255,255); knob.BorderSizePixel=0
    knob.ZIndex=3; crn(knob,5); knob.Parent=track

    local function fmt(v)
        if decimals>0 then return string.format("%."..decimals.."f",v)..suffix end
        return tostring(math.round(v))..suffix
    end
    local function setVal(v, fire)
        v = math.clamp(decimals>0 and v or math.round(v), mn, mx); val=v
        local pct=(v-mn)/(mx-mn)
        fill.Size=UDim2.new(pct,0,1,0); knob.Position=UDim2.new(pct,0,0.5,0)
        valLbl.Text=fmt(v); if fire then cb(v) end
    end
    setVal(val, false)

    local dragging=false
    local function comp(x) return mn+math.clamp((x-track.AbsolutePosition.X)/track.AbsoluteSize.X,0,1)*(mx-mn) end
    track.InputBegan:Connect(function(i)
        if i.UserInputType==Enum.UserInputType.MouseButton1 or i.UserInputType==Enum.UserInputType.Touch then
            dragging=true; setVal(comp(i.Position.X),true)
        end
    end)
    UIS.InputChanged:Connect(function(i)
        if dragging and (i.UserInputType==Enum.UserInputType.MouseMovement or i.UserInputType==Enum.UserInputType.Touch) then
            setVal(comp(i.Position.X),true)
        end
    end)
    UIS.InputEnded:Connect(function(i)
        if i.UserInputType==Enum.UserInputType.MouseButton1 or i.UserInputType==Enum.UserInputType.Touch then
            dragging=false
        end
    end)

    row.MouseEnter:Connect(function() tw(row,0.1,{BackgroundColor3=T.hover}) end)
    row.MouseLeave:Connect(function() tw(row,0.1,{BackgroundColor3=T.card}) end)

    return { SetValue=function(_,v) setVal(v,true) end, GetValue=function(_) return val end }
end

